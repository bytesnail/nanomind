"""实验 002: FineWeb-Edu 数据集全量增量分析

目的：
- 对HuggingFaceFW/fineweb-edu数据集进行全量分析（不采样）
- 采用增量处理策略，逐文件统计并累积结果
- 支持断点续传，可随时恢复
- 生成完整的统计报告

运行命令：
    python experiments/exp_001_dataset_exploration_fineweb_edu.py

预期输出：
- 完整的全量统计数据（JSON）
- 进度检查点（支持断点续传）
- 详细的分析日志

预计耗时：~10小时（基于逐文件处理2410个parquet文件）
"""

# 标准库
import os
import sys
import json
import random
import logging
import pickle
from datetime import datetime
from typing import Dict, Any, List, Optional
from pathlib import Path
from collections import Counter
from urllib.parse import urlparse
from dataclasses import dataclass, asdict

# 第三方库
import numpy as np
import pandas as pd

try:
    from tqdm import tqdm

    TQDM_AVAILABLE = True
except ImportError:
    TQDM_AVAILABLE = False

# 全局配置
DATA_DIR: str = "data/datasets/HuggingFaceFW/fineweb-edu/data"
OUTPUT_DIR: str = "outputs"
LOG_DIR: str = f"{OUTPUT_DIR}/logs"
RESULT_DIR: str = f"{OUTPUT_DIR}/results"
CHECKPOINT_DIR: str = f"{RESULT_DIR}/checkpoints"
RANDOM_SEED: int = 42


@dataclass
class FileStatistics:
    """单个文件的统计信息。"""

    file_name: str
    file_path: str
    snapshot: str
    row_count: int
    text_length_mean: float
    text_length_median: float
    text_length_std: float
    text_length_min: int
    text_length_max: int
    token_count_mean: float
    token_count_median: float
    token_count_min: int
    token_count_max: int
    score_mean: float
    score_median: float
    score_min: float
    score_max: float
    int_score_distribution: Dict[int, int]


@dataclass
class GlobalStatistics:
    """全局累计统计信息。"""

    total_rows: int = 0
    total_tokens: int = 0
    snapshot_stats: Dict[str, Dict[str, Any]] = None
    language_distribution: Counter = None
    language_score_mean: float = 0.0
    domain_distribution: Counter = None
    processed_files: List[str] = None
    file_statistics: List[FileStatistics] = None
    start_time: str = None
    end_time: str = None


def set_seed(seed: int = RANDOM_SEED) -> None:
    """设置所有随机种子。"""
    random.seed(seed)
    np.random.seed(seed)


def get_timestamp() -> str:
    """获取当前时间戳字符串。"""
    return datetime.now().strftime("%Y%m%d_%H%M%S")


def setup_logging(log_file: str) -> logging.Logger:
    """设置日志记录器。"""
    logger = logging.getLogger("exp_001")
    logger.setLevel(logging.INFO)
    logger.handlers.clear()

    fh = logging.FileHandler(log_file, encoding="utf-8")
    fh.setLevel(logging.INFO)

    ch = logging.StreamHandler()
    ch.setLevel(logging.INFO)

    formatter = logging.Formatter(
        "%(asctime)s - %(levelname)s - %(message)s", datefmt="%Y-%m-%d %H:%M:%S"
    )
    fh.setFormatter(formatter)
    ch.setFormatter(formatter)

    logger.addHandler(fh)
    logger.addHandler(ch)

    return logger


def extract_domain(url: str) -> str:
    """从URL中提取域名。"""
    try:
        parsed = urlparse(url)
        return parsed.netloc
    except Exception:
        return "unknown"


def get_all_parquet_files(data_dir: str) -> List[str]:
    """
    获取所有parquet文件路径。

    Args:
        data_dir: 数据目录

    Returns:
        排序后的parquet文件列表
    """
    parquet_files = []

    for root, dirs, files in os.walk(data_dir):
        for file in files:
            if file.endswith(".parquet"):
                full_path = os.path.join(root, file)
                parquet_files.append(full_path)

    return sorted(parquet_files)


def save_checkpoint(global_stats: GlobalStatistics, checkpoint_path: str) -> None:
    """
    保存进度检查点。

    Args:
        global_stats: 全局统计信息
        checkpoint_path: 检查点文件路径
    """
    checkpoint_data = {
        "global_stats": asdict(global_stats),
        "timestamp": datetime.now().isoformat(),
    }

    with open(checkpoint_path, "wb") as f:
        pickle.dump(checkpoint_data, f)


def load_checkpoint(checkpoint_path: str) -> Optional[GlobalStatistics]:
    """
    加载进度检查点。

    Args:
        checkpoint_path: 检查点文件路径

    Returns:
        恢复的全局统计信息，如果不存在则返回None
    """
    if not os.path.exists(checkpoint_path):
        return None

    with open(checkpoint_path, "rb") as f:
        return pickle.load(f)


def analyze_file(file_path: str, logger: logging.Logger) -> Optional[FileStatistics]:
    """
    分析单个parquet文件。

    Args:
        file_path: parquet文件路径
        logger: 日志记录器

    Returns:
        文件统计信息，如果失败则返回None
    """
    try:
        file_name = os.path.basename(file_path)
        snapshot = os.path.basename(os.path.dirname(file_path))

        logger.info(f"  分析文件: {file_name}")

        # 只加载需要的列，减少内存占用
        cols = [
            "text",
            "token_count",
            "score",
            "int_score",
            "language",
            "language_score",
        ]
        df = pd.read_parquet(file_path, engine="pyarrow", columns=cols)

        row_count = len(df)

        if row_count == 0:
            logger.warning(f"    文件为空: {file_name}")
            return None

        # 计算文本长度
        text_lengths = df["text"].str.len()
        text_stats = {
            "mean": float(text_lengths.mean()),
            "median": float(text_lengths.median()),
            "std": float(text_lengths.std()),
            "min": int(text_lengths.min()),
            "max": int(text_lengths.max()),
        }

        # Token统计
        token_stats = {
            "mean": float(df["token_count"].mean()),
            "median": float(df["token_count"].median()),
            "min": int(df["token_count"].min()),
            "max": int(df["token_count"].max()),
        }

        # 质量分数统计
        score_stats = {
            "mean": float(df["score"].mean()),
            "median": float(df["score"].median()),
            "min": float(df["score"].min()),
            "max": float(df["score"].max()),
        }

        # 整数分数分布
        int_score_dist = df["int_score"].value_counts().to_dict()
        int_score_dist = {int(k): int(v) for k, v in int_score_dist.items()}

        # 语言分数统计
        lang_score_mean = float(df["language_score"].mean())

        return FileStatistics(
            file_name=file_name,
            file_path=file_path,
            snapshot=snapshot,
            row_count=row_count,
            text_length_mean=text_stats["mean"],
            text_length_median=text_stats["median"],
            text_length_std=text_stats["std"],
            text_length_min=text_stats["min"],
            text_length_max=text_stats["max"],
            token_count_mean=token_stats["mean"],
            token_count_median=token_stats["median"],
            token_count_min=token_stats["min"],
            token_count_max=token_stats["max"],
            score_mean=score_stats["mean"],
            score_median=score_stats["median"],
            score_min=score_stats["min"],
            score_max=score_stats["max"],
            int_score_distribution=int_score_dist,
        )

    except Exception as e:
        logger.error(f"  ❌ 文件分析失败 {file_name}: {e}")
        return None


def update_global_stats(
    global_stats: GlobalStatistics,
    file_stats: FileStatistics,
    df: pd.DataFrame,
    logger: logging.Logger,
) -> None:
    """
    用单个文件统计更新全局统计。

    Args:
        global_stats: 全局统计
        file_stats: 文件统计
        df: 数据DataFrame（用于提取语言和域名）
        logger: 日志记录器
    """
    global_stats.total_rows += file_stats.row_count
    global_stats.total_tokens += int(file_stats.token_count_mean * file_stats.row_count)

    if global_stats.processed_files is None:
        global_stats.processed_files = []
    global_stats.processed_files.append(file_stats.file_name)

    # 按快照分组统计
    if global_stats.snapshot_stats is None:
        global_stats.snapshot_stats = {}

    if file_stats.snapshot not in global_stats.snapshot_stats:
        global_stats.snapshot_stats[file_stats.snapshot] = {
            "row_count": 0,
            "files": [],
        }

    snapshot_info = global_stats.snapshot_stats[file_stats.snapshot]
    snapshot_info["row_count"] += file_stats.row_count
    snapshot_info["files"].append(file_stats.file_name)

    logger.debug(
        f"    已处理快照 {file_stats.snapshot}: 总计 {snapshot_info['row_count']} 行"
    )


def aggregate_all_statistics(
    global_stats: GlobalStatistics, logger: logging.Logger
) -> None:
    """
    聚合所有统计信息并生成报告。

    Args:
        global_stats: 全局统计
        logger: 日志记录器
    """
    logger.info("开始聚合同步统计...")

    # 按快照聚合统计
    snapshot_summary = {}
    for snapshot_name, snapshot_info in global_stats.snapshot_stats.items():
        snapshot_summary[snapshot_name] = {
            "row_count": snapshot_info["row_count"],
            "file_count": len(snapshot_info["files"]),
        }

    global_stats.snapshot_stats = snapshot_summary

    logger.info(f"  聚合了 {len(snapshot_summary)} 个快照的统计")


def print_section(title: str, data: Dict[str, Any]) -> None:
    """格式化打印一个部分的信息。"""
    print(f"\n{'=' * 60}")
    print(f"  {title}")
    print(f"{'=' * 60}")
    for key, value in data.items():
        if isinstance(value, float):
            print(f"  {key:25s}: {value:.4f}")
        else:
            print(f"  {key:25s}: {value}")


def save_final_results(
    global_stats: GlobalStatistics, output_dir: str, logger: logging.Logger
) -> None:
    """
    保存最终分析结果。

    Args:
        global_stats: 全局统计
        output_dir: 输出目录
        logger: 日志记录器
    """
    json_file = f"{output_dir}/exp_001_full_statistics.json"

    result = {
        "metadata": {
            "experiment": "FineWeb-Edu 全量分析",
            "dataset": "HuggingFaceFW/fineweb-edu",
            "total_files_processed": len(global_stats.processed_files)
            if global_stats.processed_files
            else 0,
            "start_time": global_stats.start_time,
            "end_time": global_stats.end_time,
        },
        "global_statistics": {
            "total_rows": global_stats.total_rows,
            "total_tokens": global_stats.total_tokens,
            "average_rows_per_file": (
                global_stats.total_rows / len(global_stats.processed_files)
                if global_stats.processed_files
                else 0
            ),
        },
        "snapshot_statistics": global_stats.snapshot_stats,
    }

    with open(json_file, "w", encoding="utf-8") as f:
        json.dump(result, f, ensure_ascii=False, indent=2)

    logger.info(f"  ✅ 最终结果已保存到: {json_file}")


def main() -> None:
    """
    主函数，执行全量增量分析流程。
    """
    set_seed(RANDOM_SEED)

    # 创建输出目录
    os.makedirs(LOG_DIR, exist_ok=True)
    os.makedirs(RESULT_DIR, exist_ok=True)
    os.makedirs(CHECKPOINT_DIR, exist_ok=True)

    # 设置日志
    timestamp = get_timestamp()
    log_file = f"{LOG_DIR}/exp_001_{timestamp}.log"
    logger = setup_logging(log_file)

    global_stats = GlobalStatistics(start_time=datetime.now().isoformat())

    print("\n" + "=" * 60)
    print("  实验 002: FineWeb-Edu 数据集全量增量分析")
    print("=" * 60)
    print(f"  运行时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print()

    # 获取所有parquet文件
    print_section("准备数据", {"状态": "扫描文件..."})
    all_files = get_all_parquet_files(DATA_DIR)
    print_section("文件统计", {"文件数量": len(all_files)})
    logger.info(f"发现 {len(all_files)} 个parquet文件")

    # 检查是否有断点
    checkpoint_path = f"{CHECKPOINT_DIR}/exp_001_checkpoint.pkl"
    loaded_checkpoint = load_checkpoint(checkpoint_path)

    if loaded_checkpoint:
        logger.info(f"加载断点: {loaded_checkpoint.get('timestamp')}")
        global_stats = loaded_checkpoint.get("global_stats", global_stats)
        processed_files = (
            set(global_stats.processed_files) if global_stats.processed_files else set()
        )
    else:
        processed_files = set()
        global_stats.file_statistics = []

    # 处理所有文件
    print("\n" + "=" * 60)
    print("  开始文件级增量分析")
    print("=" * 60)

    progress_bar = (
        tqdm(all_files, desc="处理文件", unit="文件") if TQDM_AVAILABLE else all_files
    )

    failed_files = []

    for idx, file_path in enumerate(progress_bar, start=1):
        if file_path in processed_files:
            logger.debug(f"  跳过已处理文件: {os.path.basename(file_path)}")
            continue

        # 读取必要字段
        try:
            cols = ["text", "language"]
            df_sample = pd.read_parquet(file_path, engine="pyarrow", columns=cols)
        except Exception as e:
            logger.warning(f"  无法读取文件 {file_path}: {e}")
            continue

        file_stats = analyze_file(file_path, logger)

        if file_stats is None:
            failed_files.append(file_path)
            continue

        if global_stats.file_statistics is None:
            global_stats.file_statistics = []
        global_stats.file_statistics.append(file_stats)

        # 更新全局统计
        update_global_stats(global_stats, file_stats, df_sample, logger)
        processed_files.add(file_path)

        # 每100个文件保存一次检查点
        if idx % 100 == 0:
            logger.info(f"  保存检查点 (已处理 {idx}/{len(all_files)} 文件)")
            save_checkpoint(global_stats, checkpoint_path)

    # 聚合同步统计
    print("\n" + "=" * 60)
    print("  聚合同步统计")
    print("=" * 60)
    aggregate_all_statistics(global_stats, logger)

    # 打印摘要
    print_section("总数据量", {"总行数": f"{global_stats.total_rows:,}"})
    print_section("总Token数", {"总Token数": f"{global_stats.total_tokens:,}"})
    print_section(
        "已处理文件",
        {
            "数量": len(global_stats.processed_files)
            if global_stats.processed_files
            else 0
        },
    )
    print_section("失败文件", {"数量": len(failed_files)})

    if failed_files:
        print_section(
            "失败文件列表", {"文件": [os.path.basename(f) for f in failed_files[:10]]}
        )
        logger.error(f" {len(failed_files)} 个文件处理失败")

    # 保存最终结果
    global_stats.end_time = datetime.now().isoformat()
    print("\n" + "=" * 60)
    print("  保存结果")
    print("=" * 60)
    save_final_results(global_stats, RESULT_DIR, logger)

    # 清理检查点
    logger.info("清理检查点...")
    if os.path.exists(checkpoint_path):
        os.remove(checkpoint_path)
        logger.info(f"  ✅ 已删除检查点: {checkpoint_path}")

    # 总结
    print("\n" + "=" * 60)
    print("  总结")
    print("=" * 60)
    print("  ✅ 全量增量分析完成")
    print(
        f"  ✅ 处理文件: {len(global_stats.processed_files) if global_stats.processed_files else 0}/{len(all_files)}"
    )
    print(f"  ✅ 总数据行数: {global_stats.total_rows:,}")
    print(f"  ✅ 结果文件: {RESULT_DIR}/exp_001_full_statistics.json")
    print("=" * 60 + "\n")


if __name__ == "__main__":
    main()
